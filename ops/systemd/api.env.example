APP_ROOT=__APP_ROOT__
NODE_ENV=production
PORT=4000
DB_PATH=./data/noctification.db
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_HOURS=8
CORS_ORIGIN=http://IP_DA_VM
COOKIE_SECURE=true
ALLOW_INSECURE_FIXED_ADMIN=false
ADMIN_LOGIN=CHANGE_ME_ADMIN_LOGIN
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_NAME=Administrador
ENABLE_REMINDER_SCHEDULER=false
ENABLE_TASK_AUTOMATION_SCHEDULER=false
TASK_AUTOMATION_DUE_SOON_MINUTES=120
TASK_AUTOMATION_STALE_HOURS=24

# Em producao:
# - APP_ROOT sera alinhado automaticamente pelo script de deploy
# - troque JWT_SECRET por um segredo forte e unico
# - configure ADMIN_LOGIN, ADMIN_PASSWORD e ADMIN_NAME
# - com HTTPS, mantenha COOKIE_SECURE=true
# - em deploy HTTP controlado, ajuste COOKIE_SECURE=false
# - mantenha ALLOW_INSECURE_FIXED_ADMIN=false
# - mantenha ENABLE_TASK_AUTOMATION_SCHEDULER=false ate o rollout controlado
# - ajuste TASK_AUTOMATION_* apenas se houver motivo operacional claro
